#!/usr/bin/env zsh
set -euo pipefail
cd "$(dirname "$0")"

filter="${1:-}"

if ! sudo -n true 2>/dev/null; then
    if [[ -t 0 ]]; then
        sudo -v || { echo "sudo validation failed"; exit 1; }
        # keep the ticket alive for the whole run; password never touches disk
        ( while sudo -n -v 2>/dev/null; do sleep 50; done ) &
        sudo_keepalive_pid=$!
        trap 'kill "$sudo_keepalive_pid" 2>/dev/null' EXIT
    else
        echo "note: no sudo ticket and no terminal to ask — sudo-needing steps may fail"
    fi
fi

for module in modules/[0-9]*.sh; do
    name="$(basename "$module")"
    if [[ -n "$filter" && "$name" != "$filter"* ]]; then
        continue
    fi
    echo
    echo "───────── $name ─────────"
    zsh "$module"
done

if [[ -z "$filter" || "$filter" == 30* || "$filter" == 55* ]]; then
    echo
    echo "───────── workspace-launch ─────────"
    zsh workspace-launch
else
    echo
    echo "note: skipped workspace-launch (full ./sync or ./workspace-launch runs it)"
fi

drift="$(git status --porcelain -- config/ 2>/dev/null)"
if [[ -n "$drift" ]]; then
    echo
    echo "config drift (apps wrote through the symlinks — commit or reset):"
    printf '%s\n' "$drift"
fi

echo
echo "All done."

#!/bin/bash
# JankyBorders stock example config: https://github.com/FelixKratz/JankyBorders
# Single source of truth for border options: the AeroSpace fork (BordersSync)
# hides the border on floating workspaces (width=0.0) and restores it by
# re-running this file against the live daemon.
options=(
    style=round
    width=6.0
    hidpi=off
    active_color=0xffe2e2e3
    inactive_color=0xff414550
)

borders "${options[@]}"

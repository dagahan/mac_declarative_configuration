{
    "global": {
        "show_in_menu_bar": false
    },
    "profiles": [
        {
            "name": "mac_setup",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" },
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Disable Cmd+Q and Cmd+W (Cmd+Shift+Q still works)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "key_code": "q", "modifiers": { "mandatory": ["command"], "optional": ["caps_lock"] } },
                                "to": []
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "w", "modifiers": { "mandatory": ["command"], "optional": ["caps_lock"] } },
                                "to": []
                            }
                        ]
                    },
                    {
                        "description": "Cmd+Space -> Ainto launcher (intercepted before Spotlight; emits Ainto's Cmd+Shift+Space hotkey)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "mandatory": ["command"], "optional": ["caps_lock"] }
                                },
                                "to": [
                                    { "key_code": "spacebar", "modifiers": ["left_command", "left_shift"] }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "F3 (plain press, no fn/modifiers) -> AeroSpace mission-control overlay",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "f3",
                                    "modifiers": { "optional": ["caps_lock"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/aerospace mission-control" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "mission_control",
                                    "modifiers": { "optional": ["caps_lock", "fn"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/aerospace mission-control" }]
                            }
                        ]
                    }
                ]
            }
        }
    ]
}

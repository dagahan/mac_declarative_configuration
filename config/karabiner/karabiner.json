{
    "profiles": [
        {
            "name": "mac_setup",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" },
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Cmd+Tab -> nothing on tiling workspaces (AltTab handles it on workspace 1)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "conditions": [
                                    { "type": "variable_if", "name": "aerospace_tiling", "value": 1 }
                                ],
                                "from": {
                                    "key_code": "tab",
                                    "modifiers": { "mandatory": ["command"], "optional": ["any"] }
                                },
                                "to": [{ "key_code": "vk_none" }]
                            }
                        ]
                    },
                    {
                        "description": "Cmd+W quits AyuGram on any workspace (it hides to tray otherwise)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^one\\.ayugram\\.AyuGramDesktop$"] }
                                ],
                                "from": {
                                    "key_code": "w",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "key_code": "q", "modifiers": ["command"] }]
                            }
                        ]
                    },
                    {
                        "description": "Cmd+W quits the app on tiling workspaces (kills tray-hiders for real)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "conditions": [
                                    { "type": "variable_if", "name": "aerospace_tiling", "value": 1 }
                                ],
                                "from": {
                                    "key_code": "w",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "key_code": "q", "modifiers": ["command"] }]
                            }
                        ]
                    },
                    {
                        "description": "Disable Mission Control key (F3, both event forms)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "apple_vendor_keyboard_key_code": "expose_all" },
                                "to": [{ "key_code": "vk_none" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "f3",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "vk_none" }]
                            }
                        ]
                    }
                ]
            }
        }
    ]
}

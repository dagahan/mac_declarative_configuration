#!/usr/bin/env zsh
export PATH="/opt/homebrew/bin:$PATH"

force=0
[[ "${1:-}" == "--force" ]] && force=1

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33mwarning:\033[0m %s\n' "$*"; }

restart_app() {
    local proc="$1" target="${2:-$1}"
    if pgrep -qx "$proc"; then
        pkill -x "$proc"
        # wait for real exit: a half-dead instance still holds hotkeys and state files
        for _ in {1..50}; do
            pgrep -qx "$proc" || break
            sleep 0.2
        done
        pgrep -qx "$proc" && { pkill -9 -x "$proc"; sleep 0.5; }
    fi
    if [[ "$target" == /* ]]; then
        [[ -e "$target" ]] || { warn "$proc not installed — skipping"; return 0; }
    elif ! open -Ra "$target" 2>/dev/null; then
        warn "$proc not installed — skipping"
        return 0
    fi
    # open -g returns success even when the app fails to stay up; verify and retry.
    local open_arg; [[ "$target" == /* ]] && open_arg=("$target") || open_arg=(-a "$target")
    for attempt in 1 2 3; do
        open -g "${open_arg[@]}" 2>/dev/null
        for _ in {1..15}; do
            pgrep -qx "$proc" && { log "$proc"; return 0; }
            sleep 0.2
        done
        warn "$proc didn't come up (attempt $attempt) — retrying"
    done
    warn "$proc failed to launch after 3 attempts"
    return 1
}

# start only if not already running — running apps pick up config changes themselves
ensure_app() {
    local proc="$1" target="${2:-$1}"
    if (( !force )) && pgrep -qx "$proc"; then
        log "$proc already running"
        return 0
    fi
    restart_app "$proc" "$target"
}

# restart only when a rebuild flagged it (or it's not running at all)
flagged() {
    local flag="/tmp/mac-setup-relaunch-$1"
    [[ -f "$flag" ]] && { rm -f "$flag"; return 0; }
    (( force )) && return 0
    pgrep -qx "$1" || return 0
    return 1
}

log "karabiner services"
launchctl kickstart -k "gui/$(id -u)/org.pqrs.service.agent.karabiner_console_user_server" 2>/dev/null
ensure_app Karabiner-Menu "/Library/Application Support/org.pqrs/Karabiner-Elements/Karabiner-Menu.app"

if flagged AeroSpace; then
    prev_ws="$(aerospace list-workspaces --focused 2>/dev/null | head -1)"
    restart_app AeroSpace
    for _ in {1..12}; do
        aerospace list-workspaces --focused >/dev/null 2>&1 && break
        sleep 1
    done
    if aerospace list-workspaces --focused >/dev/null 2>&1; then
        if [[ -n "${prev_ws:-}" && "$(aerospace list-workspaces --focused 2>/dev/null | head -1)" != "$prev_ws" ]]; then
            aerospace workspace "$prev_ws" 2>/dev/null
            log "refocused workspace $prev_ws"
        fi
    else
        warn "AeroSpace server unreachable — grant Accessibility, then rerun mac-workspace-launch"
    fi
else
    log "AeroSpace unchanged — not restarted"
fi
aerospace reload-config 2>/dev/null && log "aerospace config reloaded"

if command -v borders >/dev/null && [[ -x "$HOME/.config/borders/bordersrc" ]]; then
    (( force )) && pkill -x borders 2>/dev/null
    # running daemon absorbs the options; otherwise this becomes the daemon
    "$HOME/.config/borders/bordersrc" &>/dev/null &!
    log "borders"
else
    warn "borders not installed — skipping"
fi

if flagged AltTab; then
    restart_app AltTab
else
    log "AltTab unchanged — not restarted"
fi
ensure_app LinearMouse
ensure_app Easydict
ensure_app Hammerspoon /Applications/Hammerspoon.app

if [[ -f /tmp/mac-setup-relaunch-Dock ]] || (( force )); then
    rm -f /tmp/mac-setup-relaunch-Dock
    killall Dock 2>/dev/null
    log "Dock"
else
    log "Dock unchanged — not restarted"
fi

log "workspace up"
